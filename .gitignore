# ==========================================
# 1. 临时文件与缓存 (千万别传，容易引起冲突)
# ==========================================
# Python 字节码缓存文件
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 2. 数据集 (太大，且可能涉及版权/隐私)
# ==========================================
# 忽略 raw 和 processed 下的所有数据，但保留这两个空文件夹以维持结构
datasets/raw/*
!datasets/raw/.gitkeep
datasets/processed/*
!datasets/processed/.gitkeep

# ==========================================
# 3. 运行结果与模型输出 (体积大，且应该由代码自动生成)
# ==========================================
# 本地预测结果
*.csv
# 但你可能想保留你刚才用来导出目录树的文本文档，所以不加 *.txt

# 忽略保存的模型文件
saved_models/

# 忽略自动生成的图表
plots/

# 你项目里似乎有一个空的 RF 文件夹，如果不需要追踪也可以忽略
RF/

# ==========================================
# 4. IDE 配置文件 (带有你电脑的绝对路径和个人习惯，传上去会影响队友)
# ==========================================
# PyCharm / IntelliJ IDEA 配置
.idea/

# ==========================================
# 5. 虚拟环境 (这玩意通常几百MB到几个GB，绝对不能传)
# ==========================================
# 假设你以后可能会在项目里建虚拟环境，提前屏蔽掉
venv/
env/
.venv/
.env/

# ==========================================
# 6. 配置/密钥文件 (防患于未然)
# ==========================================
# 如果你的 config.yaml 里以后会写数据库密码，可以考虑把它忽略
# 但是目前作为项目的结构说明，你可以选择保留它，或者复制一份 config_template.yaml 传上去
# 这里我暂时帮你保留 config.yaml，不加忽略规则。